---
import type { Locale, Project } from "../data/projects";
import { localePath, ui } from "../i18n";

interface Props {
  project: Project;
  locale: Locale;
}

const { project, locale } = Astro.props;
const content = project.content[locale] ?? project.content.en;
const t = ui[locale];
---

<a class="project-card" href={localePath(locale, `projects/${project.slug}`)}>
  <div class="project-card-topline">
    <span class="project-code">{project.code}</span>
    <span class="status-badge">{t.labels.validated}</span>
  </div>
  <p class="project-tags">{project.technologies.slice(0, 5).join(" · ")}</p>
  <h3>{content.title}</h3>
  <p>{content.summary}</p>
  <span class="card-link">{t.labels.details} <span aria-hidden="true">→</span></span>
</a>