---
import ProjectPage from "../../../views/ProjectPage.astro";
import { publishedProjects } from "../../../data/projects";
import { supportedLocales } from "../../../i18n";

export function getStaticPaths() {
  return supportedLocales.flatMap((lang) =>
    publishedProjects.map((project) => ({
      params: { lang, slug: project.slug },
      props: { project, locale: lang }
    }))
  );
}

const { project, locale } = Astro.props;
---
<ProjectPage project={project} locale={locale} />
