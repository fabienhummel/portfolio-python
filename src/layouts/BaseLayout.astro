---
import "../styles/global.css";
import type { Locale } from "../data/projects";
import LanguageBar from "../components/LanguageBar.astro";
import { localePath, ui } from "../i18n";

interface Props {
  locale: Locale;
  title?: string;
  description?: string;
  currentPath?: string;
}

const {
  locale,
  title = "Fabien Hummel-Knibiely — Python Developer",
  description = "Portfolio professionnel de développeur Python.",
  currentPath = ""
} = Astro.props;
const t = ui[locale];
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a class="brand" href={localePath(locale)}>FH<span>.</span></a>
        <nav class="main-nav" aria-label="Main navigation">
          <a href={localePath(locale)}>{t.nav.home}</a>
          <a href={localePath(locale, "#projects")}>{t.nav.projects}</a>
          <a href={localePath(locale, "#skills")}>{t.nav.skills}</a>
          <a href={localePath(locale, "#about")}>{t.nav.about}</a>
        </nav>
        <LanguageBar locale={locale} currentPath={currentPath} />
      </div>
    </header>
    <main><slot /></main>
    <footer class="site-footer">
      <div class="container footer-inner">
        <span>© {new Date().getFullYear()} Fabien Hummel-Knibiely</span>
        <a href="https://github.com/fabienhummel">GitHub</a>
      </div>
    </footer>
  </body>
</html>
